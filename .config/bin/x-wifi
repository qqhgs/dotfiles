#!/usr/bin/env bash
if [ -f "/run/wpa_supplicant/wlp2s0" ] ; then
    sudo rm /run/wpa_supplicant/wlp2s0 &&
    dhcpcd && sudo rfkill unblock all &&
    sudo wpa_supplicant -B -i wlp2s0 -c /etc/wpa_supplicant/$1.conf
else
    dhcpcd && sudo rfkill unblock all &&
    sudo wpa_supplicant -B -i wlp2s0 -c /etc/wpa_supplicant/$1.conf
fi
